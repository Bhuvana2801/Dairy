rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Rules for Buffalo Selling (Publicly viewable)
    match /buffalo/{document} {
      allow read, write: if true;
    }
    
    // Rules for Admin Sections (Reports, Expenses, etc.)
    match /daily/{document}      { allow read, write: if true; }
    match /expenses/{document}   { allow read, write: if true; }
    match /production/{document} { allow read, write: if true; }
    match /salaries/{document}   { allow read, write: if true; }
    
    // Default: deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
